# Django
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=complaints_db
POSTGRES_USER=complaints_user
POSTGRES_PASSWORD=complaints_pass

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:5173

# Redis (optional — falls back to in-memory cache if unset)
REDIS_URL=redis://redis:6379/0
