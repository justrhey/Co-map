# ── Co-Map Production Environment Variables ──────────────────────────
# Copy this file to .env (dev) or set these as env vars on your server.
# `source .env` before running the app, or paste into your host dashboard.

# ── Django Core ──────────────────────────────────────────────────────
# 🔑 Generate: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY="change-me-to-a-long-random-string"
# ❌ Set False for production
DJANGO_DEBUG="False"
# 🌐 Your domain(s), comma-separated
DJANGO_ALLOWED_HOSTS="comap.example.com"
# 🔒 Number of reverse proxies (nginx/Caddy) in front of Django — usually 1
DJANGO_NUM_PROXIES="1"

# ── Database ─────────────────────────────────────────────────────────
POSTGRES_DB="complaints_db"
POSTGRES_USER="complaints_user"
POSTGRES_PASSWORD="strong-db-password"
POSTGRES_HOST="localhost"       # or your managed DB host
POSTGRES_PORT="5432"

# ── Caching (Redis) ──────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379/0"    # omitting falls back to LocMemCache (dev only)

# ── Frontend & CORS ──────────────────────────────────────────────────
# 🌐 Your deployed frontend URL (where the React app lives)
FRONTEND_URL="https://comap.example.com"
# 🌐 Must match FRONTEND_URL above — ALL requests from this origin are accepted
CORS_ALLOWED_ORIGINS="https://comap.example.com"

# ── Google OAuth ─────────────────────────────────────────────────────
# 🔑 https://console.cloud.google.com/apis/credentials → OAuth 2.0 Client ID
#    Add redirect URI: https://yourdomain.com/accounts/google/login/callback/
#    Publish consent screen so tokens don't expire in 7 days
GOOGLE_CLIENT_ID="xxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-xxx"

# ── GitHub OAuth ─────────────────────────────────────────────────────
# 🔑 https://github.com/settings/developers → New OAuth App
#    Authorization callback URL: https://yourdomain.com/accounts/github/login/callback/
GITHUB_CLIENT_ID="Iv1.xxx"
GITHUB_CLIENT_SECRET="xxx"

# ── Email (SMTP) ─────────────────────────────────────────────────────
# 📧 Pick one:
#   Gmail    → https://myaccount.google.com/apppasswords (16-char app password)
#   SendGrid → dashboard API key
#   Resend   → SMTP settings in their dashboard
EMAIL_HOST="smtp.gmail.com"
EMAIL_HOST_USER="your@gmail.com"
EMAIL_HOST_PASSWORD="your-app-password"
EMAIL_PORT="587"
EMAIL_USE_TLS="True"
DEFAULT_FROM_EMAIL="Co-Map <noreply@yourdomain.com>"

# ── django-allauth ───────────────────────────────────────────────────
# 🔒 Generate HTTPS links for redirects/emails
ACCOUNT_DEFAULT_HTTP_PROTOCOL="https"
# 🚧 Set to "mandatory" to require email verification before users can report
# ACCOUNT_EMAIL_VERIFICATION="mandatory"

# ── Throttle Rates (optional defaults are generous) ──────────────────
# THROTTLE_ANON="2000/hour"
# THROTTLE_USER="8000/hour"
# THROTTLE_SUBMISSION="10/hour"

# ── Email Verification Link Expiry ───────────────────────────────────
# EMAIL_VERIFICATION_MAX_AGE="259200"    # 3 days in seconds
