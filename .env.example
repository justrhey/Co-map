# ── Co-Map Production Environment Variables ──────────────────────────
# Vercel (SPA + Django serverless) + Supabase (Postgres + Storage).
# Set these in the Vercel dashboard → Project → Settings → Environment Variables.
# For local dev, copy to .env (the dev defaults in settings.py also work as-is).

# ── Django Core ──────────────────────────────────────────────────────
# 🔑 Generate: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY="change-me-to-a-long-random-string"
# ❌ Set False for production
DJANGO_DEBUG="False"
# 🌐 Your Vercel domain(s), comma-separated (no protocol)
DJANGO_ALLOWED_HOSTS="your-app.vercel.app"
# 🔒 Vercel sits in front of the function as a proxy
DJANGO_NUM_PROXIES="1"
# 🌐 Serve Django admin/DRF assets under a namespaced path (avoids clashing with
#    the Vite SPA's /assets). Must match the rewrite in vercel.json.
DJANGO_STATIC_URL="/django-static/"

# ── Database (Supabase Postgres) ─────────────────────────────────────
# 📋 Supabase → Project Settings → Database → Connection info.
#    Use the **connection pooler** (port 6543) for serverless — direct 5432
#    connections exhaust quickly under Vercel's many short-lived functions.
POSTGRES_DB="postgres"
POSTGRES_USER="postgres.<project-ref>"
POSTGRES_PASSWORD="your-supabase-db-password"
POSTGRES_HOST="aws-0-<region>.pooler.supabase.com"
POSTGRES_PORT="6543"

# ── Caching ──────────────────────────────────────────────────────────
# Optional. Omit on Vercel (each function is isolated) → LocMemCache is used.
# REDIS_URL="redis://..."

# ── Media storage (Supabase Storage, S3-compatible) ──────────────────
# 📦 Supabase → Storage → create a PUBLIC bucket (e.g. complaint-media).
#    Then Project Settings → Storage → S3 access keys → "New access key".
SUPABASE_S3_ENDPOINT="https://<project-ref>.storage.supabase.co/storage/v1/s3"
SUPABASE_S3_REGION="ap-southeast-1"
SUPABASE_S3_BUCKET="complaint-media"
SUPABASE_S3_KEY_ID="your-storage-access-key-id"
SUPABASE_S3_SECRET="your-storage-secret-key"
# Optional override of the public URL base (auto-derived from endpoint+bucket):
# SUPABASE_PUBLIC_URL="https://<project-ref>.storage.supabase.co/storage/v1/object/public/complaint-media/"

# ── Frontend, CORS & CSRF ────────────────────────────────────────────
# On Vercel the SPA and Django share ONE origin, so CORS is barely needed —
# but set these to your Vercel URL so admin login + social auth work.
FRONTEND_URL="https://your-app.vercel.app"
CORS_ALLOWED_ORIGINS="https://your-app.vercel.app"
CSRF_TRUSTED_ORIGINS="https://your-app.vercel.app"

# ── Google OAuth ─────────────────────────────────────────────────────
# 🔑 https://console.cloud.google.com/apis/credentials → OAuth 2.0 Client ID
#    Add redirect URI: https://yourdomain.com/accounts/google/login/callback/
#    Publish consent screen so tokens don't expire in 7 days
GOOGLE_CLIENT_ID="xxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-xxx"

# ── GitHub OAuth ─────────────────────────────────────────────────────
# 🔑 https://github.com/settings/developers → New OAuth App
#    Authorization callback URL: https://yourdomain.com/accounts/github/login/callback/
GITHUB_CLIENT_ID="Iv1.xxx"
GITHUB_CLIENT_SECRET="xxx"

# ── Email (SMTP) ─────────────────────────────────────────────────────
# 📧 Pick one:
#   Gmail    → https://myaccount.google.com/apppasswords (16-char app password)
#   SendGrid → dashboard API key
#   Resend   → SMTP settings in their dashboard
EMAIL_HOST="smtp.gmail.com"
EMAIL_HOST_USER="your@gmail.com"
EMAIL_HOST_PASSWORD="your-app-password"
EMAIL_PORT="587"
EMAIL_USE_TLS="True"
DEFAULT_FROM_EMAIL="Co-Map <noreply@yourdomain.com>"

# ── django-allauth ───────────────────────────────────────────────────
# 🔒 Generate HTTPS links for redirects/emails
ACCOUNT_DEFAULT_HTTP_PROTOCOL="https"
# 🚧 Set to "mandatory" to require email verification before users can report
# ACCOUNT_EMAIL_VERIFICATION="mandatory"

# ── Throttle Rates (optional defaults are generous) ──────────────────
# THROTTLE_ANON="2000/hour"
# THROTTLE_USER="8000/hour"
# THROTTLE_SUBMISSION="10/hour"

# ── Email Verification Link Expiry ───────────────────────────────────
# EMAIL_VERIFICATION_MAX_AGE="259200"    # 3 days in seconds

# ── Sentry (error monitoring) ────────────────────────────────────
# SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@sentry.io/xxxxxx
# VITE_SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@sentry.io/xxxxxx
# VITE_SENTRY_SAMPLE_RATE=0.1
