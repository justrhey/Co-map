# Keep large/unnecessary files out of the deploy upload.
# NOTE: do NOT ignore frontend/dist — @vercel/static-build produces it and its
# output must remain in the deployment or the SPA 404s. We only drop the heavy
# source artifacts that builders regenerate or don't need.
frontend/node_modules
node_modules
.venv
venv
mediafiles
staticfiles
*.log
docs
__pycache__
*.pyc
.env
