{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "frontend/dist" }
    },
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    { "src": "/api/(.*)",    "dest": "/api/index.py" },
    { "src": "/admin(/.*)?", "dest": "/api/index.py" },
    { "src": "/accounts/(.*)", "dest": "/api/index.py" },
    { "src": "/django-static/(.*)", "dest": "/api/index.py" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
