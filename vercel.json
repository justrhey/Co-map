{
  "version": 2,
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    { "src": "/api/(.*)",    "dest": "/api/index.py" },
    { "src": "/admin(/.*)?", "dest": "/api/index.py" },
    { "src": "/accounts/(.*)", "dest": "/api/index.py" },
    { "src": "/django-static/(.*)", "dest": "/api/index.py" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
